
process {

    withName: 'Branch1:Command1Software1:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', CoreMeta.name, 'SOFTWARE1', 'COMMAND1', CoreMeta.ID, CoreMeta.TAG, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    withName: 'Branch2:Command1Software1:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', CoreMeta.name, 'SOFTWARE1', 'COMMAND1', CoreMeta.ID, CoreMeta.TAG, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    withName: 'Branch2:Command2Software2:.*' {
    
        publishDir = [ 
            enabled    : false,
            mode       : 'copy',
            overwrite  : true,
            path       : params.pubDir,
            saveAs     : { path -> 
                return [
                    'supplementary', CoreMeta.name, 'SOFTWARE2', 'COMMAND2', CoreMeta.ID, CoreMeta.TAG, 
                    new File(path).getName(),
                    ].join('/') }
            ]
    
        }

    ////LEAF_CONFIG////

    }
